# Server configuration
PORT=3456
STORAGE_PATH=./data
REFRESH_INTERVAL_MS=300000

# Data source URLs (defaults work as-is)
WHO_RSS_URL=https://www.who.int/rss-feeds/news-english.xml
PROMED_RSS_URL=https://promedmail.org/feed/
HEALTHMAP_API_URL=https://healthmap.org/getAlerts.php

# Contact email for disclaimer banner
CONTACT_EMAIL=your-email@example.com
VITE_CONTACT_EMAIL=your-email@example.com

# IMPORTANT: NEVER commit real API keys or secrets to git!
# Always keep these in your local .env file (which is gitignored)
# For Vercel, set these in the Vercel dashboard environment variables
# NEWS_API_KEY=YOUR_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_KEY_HERE
